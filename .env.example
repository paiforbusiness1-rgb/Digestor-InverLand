# GEMINI_API_KEY: Opcional. Solo si EMBEDDING_PROVIDER/OCR/GENERATION = gemini.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GROQ_API_KEY: Chat y estructuración JSON (recomendado sin Gemini).
GROQ_API_KEY="MY_GROQ_API_KEY"

# GENERATION_PROVIDER: groq | gemini | ollama
GENERATION_PROVIDER="groq"
GENERATION_MODEL="llama-3.1-8b-instant"

# Embeddings locales (Ollama) — sin GPU
EMBEDDING_PROVIDER="ollama"
EMBEDDING_MODEL="nomic-embed-text"

# OCR local (Ollama glm-ocr) — sin GPU
OCR_PROVIDER="ollama"
OCR_MODEL="glm-ocr"

OLLAMA_BASE_URL="http://127.0.0.1:11434"
# 0 = forzar CPU en cada request a Ollama
OLLAMA_NUM_GPU="0"
OLLAMA_NUM_THREAD="4"

APP_URL="MY_APP_URL"

INGEST_MODE="local"
RAG_MODE="off"

CHUNK_SIZE_TOKENS="700"
CHUNK_OVERLAP_TOKENS="70"
MIN_EXTRACTED_CHARS="80"
SQLITE_PATH="data/local-index.sqlite"

# --- Reservado Fase 4 ---
# FIREBASE_PROJECT_ID=""
# FIRESTORE_DOCUMENTS_COLLECTION="documents"
# FIRESTORE_CHUNKS_COLLECTION="chunks"
